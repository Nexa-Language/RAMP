# RAMP 评测沙盒镜像
# 基于 YatCC 依赖构建的纯净、无状态评测环境
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Asia/Shanghai

# 安装系统依赖（参考 YatCC README.md 和 task5_setup.sh）
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    python3 \
    python3-dev \
    python3-pip \
    cmake \
    ninja-build \
    default-jdk \
    bison \
    flex \
    unzip \
    wget \
    lld \
    libncurses-dev \
    libzstd-dev \
    qemu-user-static \
    gcc-riscv64-linux-gnu \
    g++-riscv64-linux-gnu \
    llvm-18 \
    clang-18 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 安装 Python 依赖
RUN pip3 install --break-system-packages openai python-dotenv pyyaml

# 设置工作目录
WORKDIR /workspace/YatCC

# 预构建 ANTLR 和 LLVM（分层缓存，加速后续启动）
# 这些在 COPY YatCC 之后执行，利用 Docker 层缓存
COPY YatCC/antlr/setup.sh ./antlr/setup.sh
RUN cd antlr && bash setup.sh

COPY YatCC/llvm/setup.sh ./llvm/setup.sh
RUN cd llvm && bash setup.sh

COPY YatCC/pybind11/setup.sh ./pybind11/setup.sh
RUN cd pybind11 && bash setup.sh

COPY YatCC/task5_setup.sh ./
RUN bash task5_setup.sh

# 复制完整 YatCC 源码
COPY YatCC/ ./

# 默认命令：保持容器运行
CMD ["/bin/bash"]