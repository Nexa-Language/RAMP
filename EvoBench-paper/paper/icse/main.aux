\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Resurrection recovers downstream evaluation signal. Without resurrection, most agents can only be evaluated at 1--2 tasks before cascading failure blocks further measurement. With resurrection, all 6 tasks become reachable, revealing hidden downstream capability.\relax }}{5}{figure.caption.6}\protected@file@percent }
\newlabel{fig:resurrection_gain}{{3}{5}{Resurrection recovers downstream evaluation signal. Without resurrection, most agents can only be evaluated at 1--2 tasks before cascading failure blocks further measurement. With resurrection, all 6 tasks become reachable, revealing hidden downstream capability.\relax }{figure.caption.6}{}}
