\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Resurrection recovers downstream evaluation signal. Without resurrection, most agents can only be evaluated at 1--2 tasks before cascading failure blocks further measurement. With resurrection, all 6 tasks become reachable, revealing hidden downstream capability.\relax }}{7}{figure.caption.5}\protected@file@percent }
\newlabel{fig:resurrection_gain}{{1}{7}{Resurrection recovers downstream evaluation signal. Without resurrection, most agents can only be evaluated at 1--2 tasks before cascading failure blocks further measurement. With resurrection, all 6 tasks become reachable, revealing hidden downstream capability.\relax }{figure.caption.5}{}}
