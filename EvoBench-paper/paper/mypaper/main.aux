\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Per-task score matrix across 18 configurations. The heatmap reveals distinct failure patterns: some models fail at early tasks (T1/T2) while others fail at later tasks (T4), demonstrating that serial evaluation captures qualitatively different information than independent-task benchmarks.\relax }}{9}{figure.caption.6}\protected@file@percent }
\newlabel{fig:ranking_shift}{{2}{9}{Per-task score matrix across 18 configurations. The heatmap reveals distinct failure patterns: some models fail at early tasks (T1/T2) while others fail at later tasks (T4), demonstrating that serial evaluation captures qualitatively different information than independent-task benchmarks.\relax }{figure.caption.6}{}}
